{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "triskelion/code-showcase",
  "version": "1.1.0",
  "title": "Code Showcase",
  "category": "triskelion",
  "icon": "html",
  "description": "Display code snippets with a premium macOS terminal aesthetic.",
  "attributes": {
    "files": {
      "type": "array",
      "default": [
        {
          "fileName": "index.js",
          "language": "javascript",
          "content": "// Tu código aquí"
        }
      ],
      "items": {
        "type": "object",
        "properties": {
          "fileName": { "type": "string" },
          "language": { "type": "string" },
          "content": { "type": "string" }
        }
      }
    },
    "activeTabIndex": {
      "type": "number",
      "default": 0
    },
    "showLineNumbers": {
      "type": "boolean",
      "default": true
    },
    "terminalTheme": {
      "type": "string",
      "default": "dark"
    }
  },
  "textdomain": "triskelion-toolkit",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}