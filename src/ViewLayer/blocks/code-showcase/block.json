{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "triskelion/code-showcase",
  "version": "1.1.0",
  "title": "Code Showcase",
  "category": "triskelion",
  "icon": "html",
  "description": "Display code snippets with a premium macOS terminal aesthetic.",
  "attributes": {
    "code": {
      "type": "string",
      "source": "html",
      "selector": "code"
    },
    "language": {
      "type": "string",
      "default": "javascript"
    },
    "fileName": {
      "type": "string",
      "default": ""
    },
    "showLineNumbers": {
      "type": "boolean",
      "default": true
    }
  },
  "textdomain": "triskelion-toolkit",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}